            </div>
          </div>
          <p>
            <span class="contact-item">
              <a href="https://wa.me/61995029627"><img src="/images/whatsappLogo.png" alt=""> </a>
              <span>(61) 99502-9627</span>
            </span>
            <span class="contact-item">
              <a href="https://www.instagram.com/estudioduetoviolino/"> <img src="/images/instagram.png" alt=""> </a>
